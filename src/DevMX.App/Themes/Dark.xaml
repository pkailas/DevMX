<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ===== BRUSHES (Dark Palette) ===== -->
  <SolidColorBrush x:Key="WindowBackground" Color="#1E1E1E"/>
  <SolidColorBrush x:Key="PanelBackground" Color="#252526"/>
  <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
  <SolidColorBrush x:Key="ForegroundBrush" Color="#D4D4D4"/>
  <SolidColorBrush x:Key="DimBrush" Color="#808080"/>
  <SolidColorBrush x:Key="AccentBrush" Color="#0E639C"/>
  <SolidColorBrush x:Key="AccentHoverBrush" Color="#1177BB"/>
  <SolidColorBrush x:Key="InputBackground" Color="#333333"/>
  <SolidColorBrush x:Key="SplitterBrush" Color="#252526"/>
  <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="#2A2A2B"/>
  <SolidColorBrush x:Key="DisabledBorderBrush" Color="#333337"/>
  <SolidColorBrush x:Key="DiffAddBrush" Color="#1E3A1E"/>
  <SolidColorBrush x:Key="DiffRemoveBrush" Color="#3A1E1E"/>
  <SolidColorBrush x:Key="DiffHunkBrush" Color="#1E2A3A"/>
  <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#1E1E1E"/>
  <SolidColorBrush x:Key="EditorForegroundBrush" Color="#D4D4D4"/>

</ResourceDictionary>
