<Window x:Class="DevMX.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DevMX.App.ViewModels;assembly=DevMX.App.ViewModels"
        xmlns:app="clr-namespace:DevMX.App"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="{Binding WindowTitle}" Width="1400" Height="900"
        MinWidth="800" MinHeight="500"
        FontSize="{Binding FontSize}">

  <Window.InputBindings>
    <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewConversationCommand}"/>
    <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding FocusSearchCommand}"/>
    <KeyBinding Key="B" Modifiers="Ctrl" Command="{Binding ToggleSidebarCommand}"/>
    <KeyBinding Key="OemPlus" Modifiers="Ctrl" Command="{Binding IncreaseFontSizeCommand}"/>
    <KeyBinding Key="OemMinus" Modifiers="Ctrl" Command="{Binding DecreaseFontSizeCommand}"/>
    <KeyBinding Key="D0" Modifiers="Ctrl" Command="{Binding ResetFontSizeCommand}"/>
    <KeyBinding Key="Escape" Command="{Binding Chat.StopCommand}"/>
  </Window.InputBindings>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolVis"/>
    <app:EnumToBoolConverter x:Key="EnumToBool"/>
    <app:StringEqualsBoolConverter x:Key="StringEquals"/>

    <!-- Chat entry templates by Kind -->
    <DataTemplate x:Key="UserEntryTemplate">
      <Grid Margin="0,2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="1"
                Background="{DynamicResource AccentBrush}"
                CornerRadius="6" Padding="10,6"
                Margin="0,0,20,0">
          <TextBox Text="{Binding Text, Mode=OneWay}" TextWrapping="Wrap"
                   Foreground="White"
                   IsReadOnly="True" BorderThickness="0" Background="Transparent"
                   IsReadOnlyCaretVisible="False" IsTabStop="False"
                   Padding="0"/>
        </Border>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="AssistantEntryTemplate">
      <Border Margin="0,2" Padding="10,6">
        <TextBox Text="{Binding Text, Mode=OneWay}" TextWrapping="Wrap"
                 Foreground="{DynamicResource ForegroundBrush}"
                 IsReadOnly="True" BorderThickness="0" Background="Transparent"
                 IsReadOnlyCaretVisible="False" IsTabStop="False"
                 Padding="0"/>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="ToolEntryTemplate">
      <Border Margin="0,2" Padding="6,3"
              Background="{DynamicResource InputBackground}"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
          <!-- Clickable variant: hyperlink-style TextBlock with click handler -->
          <TextBlock FontFamily="{DynamicResource MonospaceFontFamily}"
                     Text="{Binding Text}"
                     Foreground="{DynamicResource AccentBrush}"
                     TextDecorations="Underline"
                     Cursor="Hand"
                     Visibility="Collapsed">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsClickable}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
            <TextBlock.InputBindings>
              <MouseBinding Gesture="LeftClick"
                            Command="{Binding DataContext.Chat.OpenToolFileCommand, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                            CommandParameter="{Binding}"/>
            </TextBlock.InputBindings>
          </TextBlock>
          <!-- Non-clickable variant: selectable TextBox -->
          <TextBox FontFamily="{DynamicResource MonospaceFontFamily}"
                   Text="{Binding Text, Mode=OneWay}"
                   Foreground="{DynamicResource DimBrush}"
                   IsReadOnly="True" BorderThickness="0" Background="Transparent"
                   IsReadOnlyCaretVisible="False" IsTabStop="False"
                   Padding="0"
                   Visibility="Visible">
            <TextBox.Style>
              <Style TargetType="TextBox">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsClickable}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBox.Style>
          </TextBox>
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="InfoEntryTemplate">
      <Border Margin="0,4" Padding="8,6"
              Background="{DynamicResource PanelBackground}"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
              CornerRadius="4">
        <TextBox Text="{Binding Text, Mode=OneWay}" TextWrapping="Wrap" Foreground="{DynamicResource DimBrush}" FontStyle="Italic"
                 IsReadOnly="True" BorderThickness="0" Background="Transparent"
                 IsReadOnlyCaretVisible="False" IsTabStop="False"
                 Padding="0"/>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="ToolSummaryEntryTemplate">
      <StackPanel>
        <!-- Toggle header row -->
        <ToggleButton IsChecked="{Binding IsExpanded, Mode=OneWay}"
                      Background="Transparent" BorderThickness="0"
                      Padding="6,3" Cursor="Hand" HorizontalAlignment="Stretch">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding IsExpanded, Converter={StaticResource EnumToBool}, ConverterParameter=collapsed}"
                       FontFamily="{DynamicResource MonospaceFontFamily}"
                       Foreground="{DynamicResource DimBrush}"
                       Margin="0,0,4,0"
                       Visibility="Collapsed">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsExpanded, Mode=OneWay}" Value="True">
                      <Setter Property="Visibility" Value="Visible"/>
                      <Setter Property="Text" Value="▾"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <TextBlock Grid.Column="0"
                       Text="▸"
                       FontFamily="{DynamicResource MonospaceFontFamily}"
                       Foreground="{DynamicResource DimBrush}"
                       Margin="0,0,4,0">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsExpanded, Mode=OneWay}" Value="True">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <TextBlock Grid.Column="1"
                       Text="{Binding Text, Mode=OneWay}"
                       FontFamily="{DynamicResource MonospaceFontFamily}"
                       Foreground="{DynamicResource DimBrush}"
                       VerticalAlignment="Center"/>
          </Grid>
        </ToggleButton>
        <!-- Collapsed children (visible when expanded) -->
        <ItemsControl ItemsSource="{Binding Children}"
                      Visibility="Collapsed">
          <ItemsControl.Style>
            <Style TargetType="ItemsControl">
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsExpanded, Mode=OneWay}" Value="True">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ItemsControl.Style>
        </ItemsControl>
      </StackPanel>
    </DataTemplate>

    <!-- Selector for chat entry kind -->
    <DataTemplate DataType="{x:Type vm:ChatEntryViewModel}">
      <ContentControl>
        <ContentControl.Style>
          <Style TargetType="ContentControl">
            <Setter Property="Content" Value="{Binding}"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding Kind}" Value="User">
                <Setter Property="ContentTemplate" Value="{StaticResource UserEntryTemplate}"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding Kind}" Value="Assistant">
                <Setter Property="ContentTemplate" Value="{StaticResource AssistantEntryTemplate}"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding Kind}" Value="Tool">
                <Setter Property="ContentTemplate" Value="{StaticResource ToolEntryTemplate}"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding Kind}" Value="Info">
                <Setter Property="ContentTemplate" Value="{StaticResource InfoEntryTemplate}"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding Kind}" Value="ToolSummary">
                <Setter Property="ContentTemplate" Value="{StaticResource ToolSummaryEntryTemplate}"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ContentControl.Style>
      </ContentControl>
    </DataTemplate>
  </Window.Resources>

  <!-- Outer Grid: menu bar (row 0), rail + content (row 1), status bar (row 2) -->
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ===== MENU BAR (row 0, spans all columns) ===== -->
    <Menu Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
          Background="{DynamicResource PanelBackground}"
          Foreground="{DynamicResource ForegroundBrush}"
          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
      <!-- File -->
      <MenuItem Header="_File" Style="{StaticResource TopLevelMenuItem}">
        <MenuItem Header="_Change Working Directory…" Command="{Binding ChangeWorkingDirectoryCommand}"/>
        <Separator/>
        <MenuItem Header="E_xit" Click="MenuExit_Click"/>
      </MenuItem>
      <!-- Conversation -->
      <MenuItem Header="_Conversation" Style="{StaticResource TopLevelMenuItem}">
        <MenuItem Header="_New" Command="{Binding NewConversationCommand}" InputGestureText="Ctrl+N"/>
        <MenuItem Header="Rename _Current" Command="{Binding RenameCurrentConversationCommand}"/>
        <MenuItem Header="_Search…" Command="{Binding FocusSearchCommand}" InputGestureText="Ctrl+F"/>
      </MenuItem>
      <!-- View -->
      <MenuItem Header="_View" Style="{StaticResource TopLevelMenuItem}">
        <MenuItem Header="Toggle _Sidebar" Command="{Binding ToggleSidebarCommand}" InputGestureText="Ctrl+B"/>
        <Separator/>
        <MenuItem Header="_Dark Theme" IsCheckable="True" IsChecked="{Binding IsDarkTheme, Mode=OneWay}" Command="{Binding SetThemeCommand}" CommandParameter="dark"/>
        <MenuItem Header="_Light Theme" IsCheckable="True" IsChecked="{Binding IsLightTheme, Mode=OneWay}" Command="{Binding SetThemeCommand}" CommandParameter="light"/>
        <Separator/>
        <MenuItem Header="Increase Font Size" Command="{Binding IncreaseFontSizeCommand}" InputGestureText="Ctrl+="/>
        <MenuItem Header="Reset Font Size" Command="{Binding ResetFontSizeCommand}" InputGestureText="Ctrl+0"/>
        <MenuItem Header="Decrease Font Size" Command="{Binding DecreaseFontSizeCommand}" InputGestureText="Ctrl+-"/>
      </MenuItem>
      <!-- Tools -->
      <MenuItem Header="_Tools" Style="{StaticResource TopLevelMenuItem}">
        <MenuItem Header="_Tool Access" Style="{StaticResource TopLevelMenuItem}">
          <MenuItem Header="_Auto" IsCheckable="True" IsChecked="{Binding CurrentToolProfile, Converter={StaticResource StringEquals}, ConverterParameter=auto, Mode=OneWay}"
                    Command="{Binding SetToolProfileMenuCommand}" CommandParameter="auto"/>
          <MenuItem Header="_Full" IsCheckable="True" IsChecked="{Binding CurrentToolProfile, Converter={StaticResource StringEquals}, ConverterParameter=full, Mode=OneWay}"
                    Command="{Binding SetToolProfileMenuCommand}" CommandParameter="full"/>
          <MenuItem Header="_Restricted" IsCheckable="True" IsChecked="{Binding CurrentToolProfile, Converter={StaticResource StringEquals}, ConverterParameter=restricted, Mode=OneWay}"
                    Command="{Binding SetToolProfileMenuCommand}" CommandParameter="restricted"/>
        </MenuItem>
        <MenuItem Header="_Reconnect" Command="{Binding ReconnectCommand}"/>
        <Separator/>
        <MenuItem Header="Open _Settings" Click="MenuOpenSettings_Click"/>
        <Separator/>
        <MenuItem Header="Rebuild &amp;&amp; Restart" Click="MenuRebuildRestart_Click"/>
      </MenuItem>
      <!-- Help -->
      <MenuItem Header="_Help" Style="{StaticResource TopLevelMenuItem}">
        <MenuItem Header="_Commands" Command="{Binding ShowHelpCommand}"/>
        <MenuItem Header="About DevMX" Command="{Binding ShowAboutCommand}"/>
      </MenuItem>
    </Menu>

    <!-- ===== RAIL (far left, row 1) ===== -->
    <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource PanelBackground}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
      <Grid>
        <!-- Collapsed rail (44px wide, icon buttons) -->
        <StackPanel x:Name="CollapsedRail" Width="44" Visibility="Collapsed"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Background="{DynamicResource PanelBackground}">
          <Button Content="&#9776;" Padding="6,10" HorizontalAlignment="Stretch" Command="{Binding ToggleSidebarCommand}" ToolTip="Toggle sidebar"/>
          <Button Content="&#128172;" Padding="6,10" HorizontalAlignment="Stretch" Click="RailChatBtn_Click" ToolTip="Conversations"/>
          <Button Content="&#9881;" Padding="6,10" HorizontalAlignment="Stretch" Click="RailSettingsBtn_Click" ToolTip="Settings"/>
        </StackPanel>

        <!-- Expanded rail (260px wide, sidebar content) -->
        <ScrollViewer x:Name="ExpandedRail" Width="300" Visibility="Collapsed"
                    HorizontalAlignment="Left" VerticalAlignment="Stretch"
                    Background="{DynamicResource PanelBackground}"
                    VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <!-- Header -->
          <StackPanel Orientation="Horizontal" Margin="10,8,10,4">
            <TextBlock Text="Conversations" FontWeight="SemiBold"
                       Foreground="{DynamicResource DimBrush}" VerticalAlignment="Center"/>
          </StackPanel>

          <!-- Search box -->
          <Border Margin="8,0,8,4" Background="{DynamicResource InputBackground}"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBox Grid.Column="0" x:Name="SearchTextBox"
                       Text="{Binding Sidebar.SearchText, UpdateSourceTrigger=PropertyChanged}"
                       Padding="6,3" BorderThickness="0" Background="Transparent"
                       VerticalContentAlignment="Center">
                <TextBox.InputBindings>
                  <KeyBinding Key="Escape" Command="{Binding Sidebar.CancelRenameCommand}"/>
                </TextBox.InputBindings>
              </TextBox>
              <TextBlock Grid.Column="0" Text="Search conversations…" Foreground="{DynamicResource DimBrush}"
                         Margin="8,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                        <Setter Property="Visibility" Value="Visible"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
              <Button Grid.Column="1" x:Name="SearchClearBtn" Content="×"
                      Padding="4,2,6,2" Background="Transparent" BorderThickness="0"
                      Foreground="{DynamicResource DimBrush}" ToolTip="Clear search"
                      VerticalAlignment="Stretch"
                      Click="SearchClearBtn_Click"
                      Visibility="{Binding Sidebar.HasSearchText, Converter={StaticResource BoolVis}}"/>
            </Grid>
          </Border>

          <!-- Conversation list -->
<ListBox ItemsSource="{Binding Sidebar.Conversations}"
                    SelectedItem="{Binding Sidebar.SelectedConversation}"
                    HorizontalAlignment="Stretch"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    Margin="4,0" BorderThickness="0"
                    SelectionChanged="ConversationListBox_SelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="2,1">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <!-- Title display -->
                    <TextBlock x:Name="TitleText"
                               Text="{Binding Title}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource ForegroundBrush}"
                               MouseDown="ConversationTitle_MouseDown">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                              <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <!-- Title edit box -->
                    <TextBox x:Name="TitleEdit"
                             Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}" Foreground="{DynamicResource ForegroundBrush}"
                             Background="{DynamicResource InputBackground}"
                             BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                             Padding="2,1" LostFocus="TitleEdit_LostFocus">
                      <TextBox.Style>
                        <Style TargetType="TextBox">
                          <Setter Property="Visibility" Value="Collapsed"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                              <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBox.Style>
                      <TextBox.InputBindings>
                        <KeyBinding Key="Enter"
                                    Command="{Binding DataContext.Sidebar.CommitRenameCommand,
                                              RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"/>
                        <KeyBinding Key="Escape"
                                    Command="{Binding DataContext.Sidebar.CancelRenameCommand,
                                              RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"/>
                      </TextBox.InputBindings>
                    </TextBox>
                    <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:HH:mm}'}" Foreground="{DynamicResource DimBrush}"/>
                  </StackPanel>
                  <!-- Rename pencil button -->
                  <Button Grid.Column="1" Content="✎" Padding="2,0,4,0"
                          Background="Transparent" BorderThickness="0"
                          Foreground="{DynamicResource DimBrush}"
                          Command="{Binding DataContext.Sidebar.BeginRenameCommand,
                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                          CommandParameter="{Binding}"
                          ToolTip="Rename conversation">
                    <Button.Style>
                      <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Button.Style>
                  </Button>
                  <!-- Delete button -->
                  <Button Grid.Column="2" Content="×" Padding="2,0,4,0"
                          Background="Transparent" BorderThickness="0"
                          Foreground="{DynamicResource DimBrush}"
                          Command="{Binding DataContext.Sidebar.DeleteConversationCommand,
                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                          CommandParameter="{Binding}"
                          ToolTip="Delete conversation">
                    <Button.Style>
                      <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Button.Style>
                  </Button>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- New conversation button -->
          <Button Content="+ New Conversation" Command="{Binding Sidebar.NewConversationCommand}"
                  Margin="8,4" HorizontalAlignment="Stretch"/>

          <!-- Reconnect button -->
          <Button Content="Reconnect" Command="{Binding ReconnectCommand}"
                  Margin="8,2,8,8" HorizontalAlignment="Stretch"/>

          <!-- Settings pane -->
          <Border x:Name="SettingsSection" Margin="8,8,8,8" Padding="8"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                  Background="{DynamicResource InputBackground}">
            <StackPanel>
              <TextBlock Text="Settings" FontWeight="SemiBold"
                         Foreground="{DynamicResource DimBrush}" Margin="0,0,0,6"/>

              <!-- Endpoint -->
              <StackPanel Margin="0,2">
                <TextBlock Text="Endpoint" Foreground="{DynamicResource DimBrush}"/>
                <TextBox Text="{Binding Settings.Endpoint, UpdateSourceTrigger=PropertyChanged}" Padding="4,2"/>
              </StackPanel>

              <!-- Model -->
              <StackPanel Margin="0,4">
                <TextBlock Text="Model (empty = auto)" Foreground="{DynamicResource DimBrush}"/>
                <TextBox Text="{Binding Settings.Model, UpdateSourceTrigger=PropertyChanged}" Padding="4,2"/>
              </StackPanel>

              <!-- Provider -->
              <StackPanel Margin="0,4">
                <TextBlock Text="Provider (openai / anthropic)" Foreground="{DynamicResource DimBrush}"/>
                <TextBox Text="{Binding Settings.Provider, UpdateSourceTrigger=PropertyChanged}" Padding="4,2"/>
              </StackPanel>

              <!-- Workdir -->
              <StackPanel Margin="0,4">
                <TextBlock Text="Workdir" Foreground="{DynamicResource DimBrush}"/>
                <TextBox Text="{Binding Settings.WorkDir, UpdateSourceTrigger=PropertyChanged}" Padding="4,2"/>
              </StackPanel>

              <!-- Theme selector -->
              <StackPanel Margin="0,4">
                <TextBlock Text="Theme" Foreground="{DynamicResource DimBrush}"/>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                  <Button Content="Dark" Padding="10,3" Command="{Binding Settings.SetThemeCommand}" CommandParameter="dark">
                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding Settings.Theme}" Value="dark"><Setter Property="Background" Value="{DynamicResource AccentBrush}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style>
                  </Button>
                  <Button Content="Light" Padding="10,3" Margin="4,0,0,0" Command="{Binding Settings.SetThemeCommand}" CommandParameter="light">
                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding Settings.Theme}" Value="light"><Setter Property="Background" Value="{DynamicResource AccentBrush}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style>
                  </Button>
                </StackPanel>
               </StackPanel>

               <!-- Tool access selector -->
               <StackPanel Margin="0,4">
                 <TextBlock Text="Tool access" Foreground="{DynamicResource DimBrush}"/>
                 <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                   <Button Content="Auto" Padding="10,3" Command="{Binding Settings.SetToolProfileCommand}" CommandParameter="auto">
                     <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding Settings.ToolProfile}" Value="auto"><Setter Property="Background" Value="{DynamicResource AccentBrush}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style>
                   </Button>
                   <Button Content="Full" Padding="10,3" Margin="4,0,0,0" Command="{Binding Settings.SetToolProfileCommand}" CommandParameter="full">
                     <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding Settings.ToolProfile}" Value="full"><Setter Property="Background" Value="{DynamicResource AccentBrush}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style>
                   </Button>
                   <Button Content="Restricted" Padding="10,3" Margin="4,0,0,0" Command="{Binding Settings.SetToolProfileCommand}" CommandParameter="restricted">
                     <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding Settings.ToolProfile}" Value="restricted"><Setter Property="Background" Value="{DynamicResource AccentBrush}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style>
                   </Button>
                 </StackPanel>
                  <TextBlock Text="applies on reconnect" Foreground="{DynamicResource DimBrush}" FontStyle="Italic" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Poll delay -->
                <StackPanel Margin="0,4">
                  <TextBlock Text="Poll delay (s)" Foreground="{DynamicResource DimBrush}"/>
                  <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBox Text="{Binding Settings.PollThrottleSeconds, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" Width="60"/>
                    <TextBlock Text="0 = off, applies on reconnect" Foreground="{DynamicResource DimBrush}" FontStyle="Italic" Margin="6,0,0,3" VerticalAlignment="Center"/>
                  </StackPanel>
                </StackPanel>

                <!-- Read-only info -->
               <Border Margin="0,6,0,4" Padding="4" Background="{DynamicResource InputBackground}">
                <StackPanel>
                  <TextBlock Foreground="{DynamicResource DimBrush}">
                    <Run Text="MCP Server:" FontWeight="SemiBold"/>
                    <LineBreak/>
                    <Run Text="{Binding Settings.ServerExe, Mode=OneWay}"/>
                  </TextBlock>
                  <TextBlock Foreground="{DynamicResource DimBrush}" Margin="0,2,0,0">
                    <Run Text="API Key:" FontWeight="SemiBold"/>
                    <LineBreak/>
                    <Run Text="{Binding Settings.ApiKeySource, Mode=OneWay}"/>
                  </TextBlock>
                </StackPanel>
              </Border>

              <!-- Apply button -->
              <Button Content="Apply &amp; Reconnect" Command="{Binding Settings.ApplyCommand}"
                      Margin="0,4,0,0" HorizontalAlignment="Stretch"/>
            </StackPanel>
          </Border>
        </StackPanel>
        </ScrollViewer>

        <!-- Always-visible thin toggle strip on far left edge -->
        <Button x:Name="ToggleRailBtn" Width="12" HorizontalAlignment="Left"
                VerticalAlignment="Top" Background="Transparent" BorderThickness="0"
                Cursor="Hand" Command="{Binding ToggleSidebarCommand}"
                ToolTip="Toggle sidebar">
          <Button.Style>
            <Style TargetType="Button">
              <Setter Property="Content" Value="▶"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                  <Setter Property="Content" Value="◀"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
        </Button>
      </Grid>
    </Border>

    <!-- ===== CONTENT COLUMN ===== -->
    <Grid Grid.Row="1" Grid.Column="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="480" MinWidth="320"/>
      </Grid.ColumnDefinitions>

      <!-- LEFT: Viewer (top) + Task Monitor (bottom) -->
      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="6"/>
          <RowDefinition Height="220" MinHeight="120"/>
        </Grid.RowDefinitions>

        <!-- Tabbed Viewer Region -->
        <TabControl Grid.Row="0"
                    ItemsSource="{Binding Viewer.Tabs}"
                    SelectedItem="{Binding Viewer.SelectedTab}"
                    Margin="4">
          <TabControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Title}" Margin="0,0,6,0"/>
                <Button Content="×" Padding="2,0,4,0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource DimBrush}"
                        Command="{Binding DataContext.Viewer.CloseTabCommand,
                                    RelativeSource={RelativeSource AncestorType=TabControl}}"
                        CommandParameter="{Binding}"
                        ToolTip="Close tab">
                  <Button.Style>
                    <Style TargetType="Button">
                      <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                          <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
                        </Trigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
              </StackPanel>
            </DataTemplate>
          </TabControl.ItemTemplate>
           <TabControl.ContentTemplate>
            <DataTemplate>
              <avalonedit:TextEditor
                  app:AvalonEditBehavior.BoundText="{Binding Content}"
                  app:AvalonEditBehavior.SyntaxExtension="{Binding FileExtension}"
                  app:AvalonEditBehavior.IsDiff="{Binding Kind, Converter={StaticResource EnumToBool}, ConverterParameter=Diff}"
                  IsReadOnly="True"
                  ShowLineNumbers="True"
                  FontFamily="{DynamicResource MonospaceFontFamily}"
                  WordWrap="True"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  BorderThickness="0"
                  Padding="4"
                  Background="{DynamicResource EditorBackgroundBrush}"
                  Foreground="{DynamicResource EditorForegroundBrush}"/>
            </DataTemplate>
           </TabControl.ContentTemplate>
        </TabControl>

        <!-- Horizontal GridSplitter -->
        <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" Background="{DynamicResource SplitterBrush}"
                      ShowsPreview="True"/>

        <!-- Task Monitor -->
        <Border Grid.Row="2" Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
          <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- Task list header -->
          <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4">
            <TextBlock Text="Tasks" FontWeight="SemiBold"
                       Foreground="{DynamicResource DimBrush}"/>
          </StackPanel>

          <!-- Task items -->
          <ListBox Grid.Row="1"
                   ItemsSource="{Binding TaskMonitor.Tasks}"
                   SelectedItem="{Binding TaskMonitor.SelectedTask, Mode=TwoWay}"
                   BorderThickness="0" Margin="4,0,4,2">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="2,1">
                  <!-- Task header row -->
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding JobId}"
                               FontFamily="{DynamicResource MonospaceFontFamily}" Foreground="{DynamicResource AccentBrush}"
                               Width="80"/>
                    <!-- State with color coding -->
                    <TextBlock Text="{Binding State}" Width="55">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{DynamicResource DimBrush}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding State}" Value="queued">
                              <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="running">
                              <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="done">
                              <Setter Property="Foreground" Value="#4EC94E"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="failed">
                              <Setter Property="Foreground" Value="#F44747"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="cancelled">
                              <Setter Property="Foreground" Value="#F44747"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding Detail}"
                               Foreground="{DynamicResource ForegroundBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <!-- Cancel button — visible only for queued/running live tasks -->
                    <Button Content="Cancel" Padding="4,1" Margin="4,0,0,0"
                            Background="Transparent" BorderBrush="#F44747" Foreground="#F44747"
                            Command="{Binding CancelTaskCommand}"
                            ToolTip="Cancel this task">
                      <Button.Style>
                        <Style TargetType="Button">
                          <Setter Property="Visibility" Value="Collapsed"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCancellable, Mode=OneWay}" Value="True">
                              <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Button.Style>
                    </Button>
                  </StackPanel>
                  <!-- Changed files as clickable links -->
                  <ItemsControl ItemsSource="{Binding ChangedFiles}" Margin="90,2,0,0">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <TextBlock
                                   FontFamily="{DynamicResource MonospaceFontFamily}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   TextDecorations="Underline"
                                   Cursor="Hand"
                                   Margin="0,0,8,0">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}">
                              <Binding/>
                            </MultiBinding>
                          </TextBlock.Text>
                          <TextBlock.ToolTip>
                            <TextBlock Text="Click to view diff"/>
                          </TextBlock.ToolTip>
                          <TextBlock.InputBindings>
                            <MouseBinding Gesture="LeftClick"
                                          Command="{Binding DataContext.TaskMonitor.OpenDiffForFileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                          CommandParameter="{Binding}"/>
                          </TextBlock.InputBindings>
                        </TextBlock>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- Journal text -->
          <TextBox Grid.Row="2"
                   Text="{Binding TaskMonitor.JournalText, Mode=OneWay}"
                   IsReadOnly="True"
                   FontFamily="{DynamicResource MonospaceFontFamily}"
                   TextWrapping="NoWrap"
                   VerticalScrollBarVisibility="Auto"
                   HorizontalScrollBarVisibility="Auto"
                   BorderThickness="0"
                   Padding="8,4"
                   Background="{DynamicResource InputBackground}"
                   Foreground="{DynamicResource DimBrush}"
                    AcceptsReturn="True"/>
          </Grid>
        </Border>
      </Grid>

      <!-- Vertical GridSplitter -->
      <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                    VerticalAlignment="Stretch" Background="{DynamicResource SplitterBrush}"
                    ShowsPreview="True"/>

      <!-- RIGHT: Chat -->
      <Border Grid.Column="2" Background="{DynamicResource PanelBackground}"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
        <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Chat header -->
        <TextBlock Grid.Row="0" Text="Chat" FontWeight="SemiBold"
                   Foreground="{DynamicResource DimBrush}" Padding="10,8"/>

        <!-- Chat entries -->
        <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="8"
                      Loaded="ChatScrollViewer_OnLoaded">
          <ItemsControl ItemsSource="{Binding Chat.Entries}"/>
        </ScrollViewer>

        <!-- Busy indicator (thin progress bar above input) -->
        <ProgressBar Grid.Row="2" IsIndeterminate="True" Height="3"
                     Visibility="{Binding Chat.IsBusy, Converter={StaticResource BoolVis}}"/>

        <!-- Input row -->
        <Grid Grid.Row="3" Margin="8,4,8,8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- Pending attachment chips -->
          <ItemsControl Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                        ItemsSource="{Binding Chat.Attachments}"
                        Visibility="{Binding Chat.HasAttachments, Converter={StaticResource BoolVis}}"
                        Margin="0,0,0,4">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{DynamicResource InputBackground}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="3" Padding="6,2" Margin="0,0,4,4">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding DisplayLabel}"
                               Foreground="{DynamicResource ForegroundBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="×" Padding="4,0" Margin="4,0,0,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource DimBrush}" ToolTip="Remove attachment"
                            Command="{Binding DataContext.Chat.RemoveAttachmentCommand,
                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBox Grid.Row="1" Grid.Column="0" x:Name="ChatInputBox"
                   Text="{Binding Chat.InputText, UpdateSourceTrigger=PropertyChanged}"
                   PreviewKeyDown="ChatInput_PreviewKeyDown"
                   Padding="8,6"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   MaxHeight="150"
                   VerticalScrollBarVisibility="Auto"
                   VerticalContentAlignment="Center"
                   AllowDrop="True"
                   PreviewDragOver="ChatInput_PreviewDragOver"
                   PreviewDrop="ChatInput_PreviewDrop"
                   IsEnabled="{Binding Chat.CanSendInput}"/>

          <Button Grid.Row="1" Grid.Column="1" Content="Send"
                  Command="{Binding Chat.SendCommand}"
                  Margin="4,0,0,0" Padding="12,6"
                  VerticalAlignment="Bottom">
            <Button.Style>
              <Style TargetType="Button">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Chat.IsBusy, Mode=OneWay}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>
          <Button Grid.Row="1" Grid.Column="1" Content="Stop"
                  Command="{Binding Chat.StopCommand}"
                  Margin="4,0,0,0" Padding="12,6"
                  VerticalAlignment="Bottom"
                  Background="#F44747" Foreground="White">
            <Button.Style>
              <Style TargetType="Button">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Chat.IsBusy, Mode=OneWay}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>
        </Grid>
          </Grid>
        </Border>
       </Grid>

        <!-- Status bar (spans both columns) -->
        <StatusBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Height="32" Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource ForegroundBrush}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="{Binding StatusText}"
                         Foreground="{DynamicResource DimBrush}" Padding="8,2"/>
              <TextBlock Text="{Binding ZoomDisplayText}"
                         Foreground="{DynamicResource DimBrush}" Padding="8,2" Opacity="0.7"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Reconnect"
                    Command="{Binding ReconnectCommand}" Background="{DynamicResource AccentBrush}" Foreground="White" Padding="6,2" Margin="4,2"
                    ToolTip="Reconnect with current settings"/>
          </Grid>
        </StatusBar>
    </Grid>
</Window>
