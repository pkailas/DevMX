<Window x:Class="DevMX.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DevMX.App.ViewModels;assembly=DevMX.App.ViewModels"
        xmlns:app="clr-namespace:DevMX.App"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="DevMX" Width="1400" Height="900"
        MinWidth="800" MinHeight="500">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolVis"/>
    <app:EnumToBoolConverter x:Key="EnumToBool"/>

    <!-- Chat entry templates by Kind -->
    <DataTemplate x:Key="UserEntryTemplate">
      <Grid Margin="0,2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="1"
                Background="{StaticResource AccentBrush}"
                CornerRadius="6" Padding="10,6"
                Margin="0,0,20,0">
          <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                     Foreground="White" FontSize="13"/>
        </Border>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="AssistantEntryTemplate">
      <Border Margin="0,2" Padding="10,6">
        <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                   Foreground="{StaticResource ForegroundBrush}" FontSize="13"/>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="ToolEntryTemplate">
      <Border Margin="0,2" Padding="6,3"
              Background="{StaticResource InputBackground}"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <TextBlock FontFamily="{StaticResource MonospaceFontFamily}"
                   FontSize="12">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Text" Value="{Binding Text}"/>
              <Setter Property="Foreground" Value="{StaticResource DimBrush}"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsClickable}" Value="True">
                  <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                  <Setter Property="TextDecorations" Value="Underline"/>
                  <Setter Property="Cursor" Value="Hand"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
          <TextBlock.InputBindings>
            <MouseBinding Gesture="LeftClick"
                          Command="{Binding DataContext.Chat.OpenToolFileCommand, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                          CommandParameter="{Binding}"/>
          </TextBlock.InputBindings>
        </TextBlock>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="InfoEntryTemplate">
      <Border Margin="0,4" Padding="8,6"
              Background="#2a2a4a"
              BorderBrush="#4a90d9" BorderThickness="1"
              CornerRadius="4">
        <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                   FontSize="12" Foreground="#8ab4f8" FontStyle="Italic"/>
      </Border>
    </DataTemplate>

    <!-- Selector for chat entry kind -->
    <DataTemplate DataType="{x:Type vm:ChatEntryViewModel}">
      <ContentControl>
        <ContentControl.Style>
          <Style TargetType="ContentControl">
            <Setter Property="Content" Value="{Binding}"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding Kind}" Value="User">
                <Setter Property="ContentTemplate" Value="{StaticResource UserEntryTemplate}"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding Kind}" Value="Assistant">
                <Setter Property="ContentTemplate" Value="{StaticResource AssistantEntryTemplate}"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding Kind}" Value="Tool">
                <Setter Property="ContentTemplate" Value="{StaticResource ToolEntryTemplate}"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding Kind}" Value="Info">
                <Setter Property="ContentTemplate" Value="{StaticResource InfoEntryTemplate}"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ContentControl.Style>
      </ContentControl>
    </DataTemplate>
  </Window.Resources>

  <!-- Outer Grid: rail | content -->
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ===== RAIL (far left) ===== -->
    <Border Grid.Column="0" Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
      <Grid>
        <!-- Collapsed rail (44px wide, icon buttons) -->
        <StackPanel x:Name="CollapsedRail" Width="44" Visibility="Collapsed"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Background="{StaticResource PanelBackground}">
          <Button Content="≡" FontSize="18" Padding="6,10"
                  HorizontalAlignment="Stretch" VerticalAlignment="Top"
                  Command="{Binding ToggleSidebarCommand}"
                  ToolTip="Toggle sidebar"/>
          <Button Content="🗨" FontSize="18" Padding="6,10"
                  HorizontalAlignment="Stretch" VerticalAlignment="Top"
                  ToolTip="Chat"/>
          <Button Content="⚙" FontSize="18" Padding="6,10"
                  HorizontalAlignment="Stretch" VerticalAlignment="Top"
                  ToolTip="Settings"/>
        </StackPanel>

        <!-- Expanded rail (260px wide, sidebar content) -->
        <StackPanel x:Name="ExpandedRail" Width="260" Visibility="Collapsed"
                    HorizontalAlignment="Left" VerticalAlignment="Stretch"
                    Background="{StaticResource PanelBackground}">
          <!-- Header -->
          <StackPanel Orientation="Horizontal" Margin="10,8,10,4">
            <TextBlock Text="Conversations" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
          </StackPanel>

          <!-- Conversation list -->
          <ListBox ItemsSource="{Binding Sidebar.Conversations}"
                   SelectedItem="{Binding Sidebar.SelectedConversation}"
                   Margin="4,0" BorderThickness="0"
                   SelectionChanged="ConversationListBox_SelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="2,1">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                               FontSize="12" Foreground="{StaticResource ForegroundBrush}"/>
                    <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:HH:mm}'}"
                               FontSize="10" Foreground="{StaticResource DimBrush}"/>
                  </StackPanel>
                  <Button Grid.Column="1" Content="×" FontSize="10" Padding="2,0,4,0"
                          Background="Transparent" BorderThickness="0"
                          Foreground="{StaticResource DimBrush}"
                          Command="{Binding DataContext.Sidebar.DeleteConversationCommand,
                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                          CommandParameter="{Binding}"
                          ToolTip="Delete conversation">
                    <Button.Style>
                      <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Button.Style>
                  </Button>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- New conversation button -->
          <Button Content="+ New Conversation" Command="{Binding Sidebar.NewConversationCommand}"
                  Margin="8,4" HorizontalAlignment="Stretch"/>

          <!-- Reconnect button -->
          <Button Content="Reconnect" Command="{Binding ReconnectCommand}"
                  Margin="8,2,8,8" HorizontalAlignment="Stretch"/>

          <!-- Settings pane -->
          <Border Margin="8,8,8,8" Padding="8"
                  BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                  Background="{StaticResource InputBackground}">
            <StackPanel>
              <TextBlock Text="Settings" FontSize="12" FontWeight="SemiBold"
                         Foreground="{StaticResource DimBrush}" Margin="0,0,0,6"/>

              <!-- Endpoint -->
              <StackPanel Margin="0,2">
                <TextBlock Text="Endpoint" FontSize="10" Foreground="{StaticResource DimBrush}"/>
                <TextBox Text="{Binding Settings.Endpoint, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="4,2"/>
              </StackPanel>

              <!-- Model -->
              <StackPanel Margin="0,4">
                <TextBlock Text="Model (empty = auto)" FontSize="10" Foreground="{StaticResource DimBrush}"/>
                <TextBox Text="{Binding Settings.Model, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="4,2"/>
              </StackPanel>

              <!-- Provider -->
              <StackPanel Margin="0,4">
                <TextBlock Text="Provider (openai / anthropic)" FontSize="10" Foreground="{StaticResource DimBrush}"/>
                <TextBox Text="{Binding Settings.Provider, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="4,2"/>
              </StackPanel>

              <!-- Workdir -->
              <StackPanel Margin="0,4">
                <TextBlock Text="Workdir" FontSize="10" Foreground="{StaticResource DimBrush}"/>
                <TextBox Text="{Binding Settings.WorkDir, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="4,2"/>
              </StackPanel>

              <!-- Read-only info -->
              <Border Margin="0,6,0,4" Padding="4" Background="#1a1a2e">
                <StackPanel>
                  <TextBlock FontSize="10" Foreground="{StaticResource DimBrush}">
                    <Run Text="MCP Server:" FontWeight="SemiBold"/>
                    <LineBreak/>
                    <Run Text="{Binding Settings.ServerExe, Mode=OneWay}" FontSize="9"/>
                  </TextBlock>
                  <TextBlock FontSize="10" Foreground="{StaticResource DimBrush}" Margin="0,2,0,0">
                    <Run Text="API Key:" FontWeight="SemiBold"/>
                    <LineBreak/>
                    <Run Text="{Binding Settings.ApiKeySource, Mode=OneWay}" FontSize="9"/>
                  </TextBlock>
                </StackPanel>
              </Border>

              <!-- Apply button -->
              <Button Content="Apply &amp; Reconnect" Command="{Binding Settings.ApplyCommand}"
                      Margin="0,4,0,0" HorizontalAlignment="Stretch"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Always-visible thin toggle strip on far left edge -->
        <Button x:Name="ToggleRailBtn" Width="12" HorizontalAlignment="Left"
                VerticalAlignment="Top" Background="Transparent" BorderThickness="0"
                Cursor="Hand" Command="{Binding ToggleSidebarCommand}"
                ToolTip="Toggle sidebar">
          <Button.Style>
            <Style TargetType="Button">
              <Setter Property="Content" Value="▶"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                  <Setter Property="Content" Value="◀"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
        </Button>
      </Grid>
    </Border>

    <!-- ===== CONTENT COLUMN ===== -->
    <Grid Grid.Column="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="480" MinWidth="320"/>
      </Grid.ColumnDefinitions>

      <!-- LEFT: Viewer (top) + Task Monitor (bottom) -->
      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="6"/>
          <RowDefinition Height="220" MinHeight="120"/>
        </Grid.RowDefinitions>

        <!-- Tabbed Viewer Region -->
        <TabControl Grid.Row="0"
                    ItemsSource="{Binding Viewer.Tabs}"
                    SelectedItem="{Binding Viewer.SelectedTab}"
                    Margin="4">
          <TabControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Title}" Margin="0,0,6,0"/>
                <Button Content="×" FontSize="10" Padding="2,0,4,0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource DimBrush}"
                        Command="{Binding DataContext.Viewer.CloseTabCommand,
                                    RelativeSource={RelativeSource AncestorType=TabControl}}"
                        CommandParameter="{Binding}"
                        ToolTip="Close tab">
                  <Button.Style>
                    <Style TargetType="Button">
                      <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                          <Setter Property="Background" Value="{StaticResource InputBackground}"/>
                        </Trigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
              </StackPanel>
            </DataTemplate>
          </TabControl.ItemTemplate>
           <TabControl.ContentTemplate>
            <DataTemplate>
              <avalonedit:TextEditor
                  app:AvalonEditBehavior.BoundText="{Binding Content}"
                  app:AvalonEditBehavior.SyntaxExtension="{Binding FileExtension}"
                  app:AvalonEditBehavior.IsDiff="{Binding Kind, Converter={StaticResource EnumToBool}, ConverterParameter=Diff}"
                  IsReadOnly="True"
                  ShowLineNumbers="True"
                  FontFamily="{StaticResource MonospaceFontFamily}"
                  FontSize="12"
                  WordWrap="False"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  BorderThickness="0"
                  Padding="4"
                  Background="#1E1E1E"
                  Foreground="#D4D4D4"/>
            </DataTemplate>
           </TabControl.ContentTemplate>
        </TabControl>

        <!-- Horizontal GridSplitter -->
        <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                      VerticalAlignment="Center" Background="{StaticResource SplitterBrush}"
                      ShowsPreview="True"/>

        <!-- Task Monitor -->
        <Border Grid.Row="2" Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
          <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- Task list header -->
          <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4">
            <TextBlock Text="Tasks" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource DimBrush}"/>
          </StackPanel>

          <!-- Task items -->
          <ListBox Grid.Row="1" ItemsSource="{Binding TaskMonitor.Tasks}"
                   BorderThickness="0" Margin="4,0,4,2">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Margin="2,1">
                  <TextBlock Text="{Binding JobId}" FontFamily="{StaticResource MonospaceFontFamily}"
                             FontSize="11" Foreground="{StaticResource AccentBrush}" Width="60"/>
                  <TextBlock Text="{Binding State}" FontSize="11"
                             Foreground="{StaticResource DimBrush}" Width="50"/>
                  <TextBlock Text="{Binding Detail}" FontSize="11"
                             Foreground="{StaticResource ForegroundBrush}"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- Journal text -->
          <TextBox Grid.Row="2"
                   Text="{Binding TaskMonitor.JournalText, Mode=OneWay}"
                   IsReadOnly="True"
                   FontFamily="{StaticResource MonospaceFontFamily}"
                   FontSize="11"
                   TextWrapping="NoWrap"
                   VerticalScrollBarVisibility="Auto"
                   HorizontalScrollBarVisibility="Auto"
                   BorderThickness="0"
                   Padding="8,4"
                   Background="{StaticResource InputBackground}"
                   Foreground="{StaticResource DimBrush}"
                    AcceptsReturn="True"/>
          </Grid>
        </Border>
      </Grid>

      <!-- Vertical GridSplitter -->
      <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                    VerticalAlignment="Stretch" Background="{StaticResource SplitterBrush}"
                    ShowsPreview="True"/>

      <!-- RIGHT: Chat -->
      <Border Grid.Column="2" Background="{StaticResource PanelBackground}"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
        <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Chat header -->
        <TextBlock Grid.Row="0" Text="Chat" FontSize="12" FontWeight="SemiBold"
                   Foreground="{StaticResource DimBrush}" Padding="10,8"/>

        <!-- Chat entries -->
        <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="8"
                      Loaded="ChatScrollViewer_OnLoaded">
          <ItemsControl ItemsSource="{Binding Chat.Entries}"/>
        </ScrollViewer>

        <!-- Busy indicator (thin progress bar above input) -->
        <ProgressBar Grid.Row="2" IsIndeterminate="True" Height="3"
                     Visibility="{Binding Chat.IsBusy, Converter={StaticResource BoolVis}}"/>

        <!-- Input row -->
        <Grid Grid.Row="3" Margin="8,4,8,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <TextBox Grid.Column="0"
                   Text="{Binding Chat.InputText, UpdateSourceTrigger=PropertyChanged}"
                   KeyDown="ChatInput_KeyDown"
                   Padding="8,6"
                   VerticalContentAlignment="Center"
                   IsEnabled="{Binding Chat.CanSendInput}"/>

          <Button Grid.Column="1" Content="Send"
                  Command="{Binding Chat.SendCommand}"
                  Margin="4,0,0,0" Padding="12,6"
                  VerticalAlignment="Center"/>
        </Grid>
          </Grid>
        </Border>
       </Grid>

        <!-- Status bar (spans both columns) -->
        <StatusBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Height="32" Background="{StaticResource PanelBackground}" Foreground="{StaticResource ForegroundBrush}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="12"
                       Foreground="{StaticResource DimBrush}" Padding="8,2"/>
            <Button Grid.Column="1" Content="Reconnect"
                    Command="{Binding ReconnectCommand}"
                    FontSize="10" Background="{StaticResource AccentBrush}" Foreground="White" Padding="6,2" Margin="4,2"
                    ToolTip="Reconnect with current settings"/>
          </Grid>
        </StatusBar>
    </Grid>
</Window>
